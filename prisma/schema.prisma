generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Locale {
  ar
  en
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role])
  @@index([isActive])
}

model Page {
  id           String            @id @default(cuid())
  key          String            @unique
  slug         String            @unique
  isPublished  Boolean           @default(false)
  sortOrder    Int               @default(0)
  translations PageTranslation[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([isPublished, sortOrder])
}

model PageTranslation {
  id             String   @id @default(cuid())
  pageId         String
  locale         Locale
  title          String
  summary        String?  @db.Text
  body           String?  @db.LongText
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@index([locale])
}

model Service {
  id              String               @id @default(cuid())
  slug            String               @unique
  icon            String?
  isPublished     Boolean              @default(false)
  sortOrder       Int                  @default(0)
  featuredImageId String?
  featuredImage   Media?               @relation("ServiceFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  translations    ServiceTranslation[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([isPublished, sortOrder])
}

model ServiceTranslation {
  id             String   @id @default(cuid())
  serviceId      String
  locale         Locale
  title          String
  summary        String?  @db.Text
  body           String?  @db.LongText
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
  @@index([locale])
}

model Sector {
  id           String              @id @default(cuid())
  slug         String              @unique
  isPublished  Boolean             @default(false)
  sortOrder    Int                 @default(0)
  projects     Project[]
  translations SectorTranslation[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([isPublished, sortOrder])
}

model SectorTranslation {
  id        String   @id @default(cuid())
  sectorId  String
  locale    Locale
  title     String
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)

  @@unique([sectorId, locale])
  @@index([locale])
}

model Project {
  id              String               @id @default(cuid())
  slug            String               @unique
  sectorId        String?
  sector          Sector?              @relation(fields: [sectorId], references: [id], onDelete: SetNull)
  isFeatured      Boolean              @default(false)
  isPublished     Boolean              @default(false)
  sortOrder       Int                  @default(0)
  featuredImageId String?
  featuredImage   Media?               @relation("ProjectFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  translations    ProjectTranslation[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([sectorId])
  @@index([isFeatured, isPublished])
  @@index([isPublished, sortOrder])
}

model ProjectTranslation {
  id             String   @id @default(cuid())
  projectId      String
  locale         Locale
  title          String
  summary        String?  @db.Text
  challenge      String?  @db.Text
  approach       String?  @db.Text
  results        String?  @db.Text
  body           String?  @db.LongText
  seoTitle       String?
  seoDescription String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([locale])
}

model Partner {
  id           String               @id @default(cuid())
  slug         String               @unique
  websiteUrl   String?
  isPublished  Boolean              @default(false)
  sortOrder    Int                  @default(0)
  logoMediaId  String?
  logoMedia    Media?               @relation("PartnerLogo", fields: [logoMediaId], references: [id], onDelete: SetNull)
  translations PartnerTranslation[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([isPublished, sortOrder])
}

model PartnerTranslation {
  id          String   @id @default(cuid())
  partnerId   String
  locale      Locale
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  partner     Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, locale])
  @@index([locale])
}

model TeamMember {
  id              String                  @id @default(cuid())
  slug            String                  @unique
  email           String?
  linkedInUrl     String?
  isPublished     Boolean                 @default(false)
  sortOrder       Int                     @default(0)
  imageMediaId    String?
  imageMedia      Media?                  @relation("TeamMemberImage", fields: [imageMediaId], references: [id], onDelete: SetNull)
  translations    TeamMemberTranslation[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([isPublished, sortOrder])
}

model TeamMemberTranslation {
  id           String     @id @default(cuid())
  teamMemberId String
  locale       Locale
  name         String
  position     String?
  bio          String?     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, locale])
  @@index([locale])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  group     String   @default("general")
  label     String?
  value     String?  @db.Text
  valueJson Json?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@index([isPublic])
}

model TranslationKey {
  id          String   @id @default(cuid())
  key         String   @unique
  group       String
  ar          String   @db.Text
  en          String?  @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  company   String?
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    MessageStatus @default(UNREAD)
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model Media {
  id                    String       @id @default(cuid())
  url                   String       @db.Text
  path                  String       @db.Text
  filename              String
  originalName          String?
  mimeType              String
  size                  Int
  altAr                 String?
  altEn                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  serviceFeaturedImages Service[]    @relation("ServiceFeaturedImage")
  projectFeaturedImages Project[]    @relation("ProjectFeaturedImage")
  partnerLogos          Partner[]    @relation("PartnerLogo")
  teamMemberImages      TeamMember[] @relation("TeamMemberImage")

  @@index([mimeType])
}
