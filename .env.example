NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Phase 2+
DATABASE_URL=mysql://root@localhost:3306/orchestrate
AUTH_SECRET=replace-with-a-long-random-secret

# Local seed defaults are used only if these are omitted.
SEED_SUPER_ADMIN_NAME=Orchestrate Super Admin
SEED_SUPER_ADMIN_EMAIL=admin@orchestrate.local
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!

# Phase 7+
# Use a stable writable folder outside deploy-wiped app output in production.
UPLOAD_DIR=/var/www/vhosts/example.com/uploads/orchestrate

# Phase 8+
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com
CONTACT_TO_EMAIL=hello@example.com
