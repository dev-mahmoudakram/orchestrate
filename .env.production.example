NEXT_PUBLIC_SITE_URL=https://example.com

# Plesk/Contabo local MySQL.
# Replace values with the database, user, and password created in Plesk.
DATABASE_URL=mysql://orchestrate_user:REPLACE_WITH_PRODUCTION_DB_PASSWORD@localhost:3306/orchestrate

# Generate a long random value before production deployment.
AUTH_SECRET=REPLACE_WITH_LONG_RANDOM_PRODUCTION_SECRET

# Seed this once for production, then store credentials securely.
SEED_SUPER_ADMIN_NAME=Orchestrate Super Admin
SEED_SUPER_ADMIN_EMAIL=admin@example.com
SEED_SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ONE_TIME_ADMIN_PASSWORD

# Stable folder outside deploy-wiped application output.
UPLOAD_DIR=/var/www/vhosts/example.com/uploads/orchestrate

# SMTP provider configured in Plesk or external mail service.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=no-reply@example.com
CONTACT_TO_EMAIL=hello@example.com
